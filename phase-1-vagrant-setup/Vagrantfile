# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # Ubuntu 22.04 LTS (Jammy) — stable, widely used in DevOps
  config.vm.box = "ubuntu/jammy64"

  # Friendly hostname inside the VM
  config.vm.hostname = "devbox"

  # Forward port 8080 on VM → 8080 on your Windows machine
  # So when the app runs inside VM, you access it at http://localhost:8080
  config.vm.network "forwarded_port", guest: 8080, host: 8080

  # Forward port 80 (Nginx) as well
  config.vm.network "forwarded_port", guest: 80, host: 8081

  # VirtualBox settings
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "devbox"
    vb.memory = "2048"   # 2 GB RAM
    vb.cpus   = 2
  end

  # Automatically run the setup script when VM first boots
  config.vm.provision "shell", path: "scripts/install-tools.sh"

end
